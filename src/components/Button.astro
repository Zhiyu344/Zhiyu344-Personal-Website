---
interface Props {
    href: string;
    variant?: 'primary' | 'secondary';
    class?: string;
    id?: string;
}
const { href, variant = 'primary', class: className = '', id } = Astro.props;

const base = 'inline-flex items-center justify-center px-8 py-3 md:py-4 md:px-10 rounded-full text-base md:text-lg font-medium transition-all duration-300 hover:-translate-y-1';

const variants = {
    primary: 'text-white bg-abyss-600 dark:bg-abyss-500 hover:bg-candle-500 dark:hover:bg-abyss-500 dark:hover:shadow-[0_0_20px_rgba(255,193,7,0.35)]',
    secondary: 'text-abyss-700 dark:text-sky-100 bg-abyss-50 dark:bg-abyss-800 hover:bg-abyss-100 dark:hover:bg-abyss-700',
};
---
<a href={href} id={id} class={`${base} ${variants[variant]} ${className}`}>
    <slot />
</a>