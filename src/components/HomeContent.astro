---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="relative overflow-hidden">
	<div class="absolute inset-0 -z-20 bg-sky-50 dark:bg-abyss-950 transition-colors duration-500"></div>
	<div class="absolute inset-0 -z-20 bg-gradient-to-br from-abyss-950 via-abyss-900 to-abyss-800 opacity-0 dark:opacity-100 transition-opacity duration-500"></div>
	<!-- Hero Section -->
	<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 text-center lg:pt-32">
    	<h1 class="text-4xl tracking-tight font-extrabold text-night-900 dark:text-sky-50 sm:text-5xl md:text-6xl">
    		<span class="block">{t('home.greeting')}</span>
    		<span class="block mt-2 text-candle-500 dark:bg-gradient-to-r dark:from-abyss-300 dark:to-sky-200 dark:bg-clip-text dark:text-transparent">
				{t('home.aka')}
			</span>
    	</h1>
    	<p class="mt-3 max-w-md mx-auto text-base text-night-600 dark:text-abyss-200 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
			{t('home.tagline')}
		</p>
		<div class="mt-10 max-w-sm mx-auto sm:max-w-none sm:flex sm:justify-center">
				<div class="space-y-4 sm:space-y-0 sm:mx-auto sm:inline-grid sm:grid-cols-2 sm:gap-5">
			<a
				href={lang === 'en' ? '/projects' : `/${lang}/projects`}
				class="flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-full text-white bg-candle-500 hover:bg-candle-600 dark:bg-abyss-500 dark:hover:bg-abyss-400 md:py-4 md:text-lg md:px-10 transition-all duration-300 hover:-translate-y-1"
			>
				{t('home.viewProjects')}
			</a>
			<a
				href={lang === 'en' ? '/blog' : `/${lang}/blog`}
				class="flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-full text-candle-700 dark:text-sky-100 bg-candle-100 dark:bg-abyss-800 hover:bg-candle-200 dark:hover:bg-abyss-700 md:py-4 md:text-lg md:px-10 transition-all duration-300 hover:-translate-y-1"
			>
				{t('home.readBlog')}
			</a>
			</div>
		</div>
    </div>

	<div class="absolute top-0 left-1/2 transform -translate-x-1/2 -z-10 w-full h-full overflow-hidden pointer-events-none">
		<div class="absolute top-10 left-10 w-72 h-72 bg-sky-200 dark:bg-abyss-400 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-3xl opacity-30 dark:opacity-40 animate-float"></div>
		<div class="absolute top-10 right-10 w-72 h-72 bg-candle-200 dark:bg-abyss-300 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-3xl opacity-30 dark:opacity-30 animate-float" style="animation-delay: 2s;"></div>
		<div class="absolute -bottom-8 left-20 w-72 h-72 bg-dusk-200 dark:bg-abyss-500 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-3xl opacity-30 dark:opacity-30 animate-float" style="animation-delay: 4s;"></div>
	</div>
</div>