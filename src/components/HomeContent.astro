---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Button from './Button.astro';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="relative overflow-hidden min-h-[85vh] flex items-center">
	<!-- Hero Section -->
	<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center w-full">
    	<h1 class="text-4xl tracking-tight font-extrabold text-night-900 dark:text-sky-50 sm:text-5xl md:text-6xl">
    		<span class="block">{t('home.greeting')}</span>
    		<span class="block mt-2 bg-gradient-to-r from-abyss-500 to-abyss-800 dark:from-abyss-300 dark:to-sky-200 bg-clip-text text-transparent">
				{t('home.aka')}
			</span>
    	</h1>
    	<p class="mt-3 max-w-md mx-auto text-base text-night-600 dark:text-abyss-200 sm:text-lg md:mt-5 md:text-xl md:max-w-3xl">
			{t('home.tagline')}
		</p>
		<div class="mt-10 max-w-sm mx-auto sm:max-w-none sm:flex sm:justify-center">
				<div class="space-y-4 sm:space-y-0 sm:mx-auto sm:inline-grid sm:grid-cols-2 sm:gap-5">
			<Button href={lang === 'en' ? '/projects' : `/${lang}/projects`} variant="primary">
				{t('home.viewProjects')}
			</Button>
			<Button href={lang === 'en' ? '/blog' : `/${lang}/blog`} variant="secondary">
				{t('home.readBlog')}
			</Button>
			</div>
		</div>
    </div>

	<div class="absolute top-0 left-1/2 transform -translate-x-1/2 -z-10 w-full h-full overflow-hidden pointer-events-none">
        <div class="absolute top-10 left-10 w-72 h-72 bg-candle-300/50 dark:bg-candle-400/25 rounded-full filter blur-3xl animate-float"></div>
        <div class="absolute top-10 right-10 w-72 h-72 bg-dusk-300/40 dark:bg-dusk-400/20 rounded-full filter blur-3xl animate-float" style="animation-delay: 2s;"></div>
        <div class="absolute -bottom-8 left-20 w-72 h-72 bg-candle-200/50 dark:bg-candle-300/20 rounded-full filter blur-3xl animate-float" style="animation-delay: 4s;"></div>
    </div>
</div>