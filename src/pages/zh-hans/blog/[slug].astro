---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id }) => id.startsWith('zh-hans/'));
  return posts.map(post => ({
    params: { slug: post.id.replace('zh-hans/', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Zhiyu344`}>
  <article class="max-w-3xl mx-auto px-4 py-16 prose dark:prose-invert">
    <h1>{post.data.title}</h1>
    <p class="text-sm text-night-500 dark:text-abyss-300">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
    <Content />
  </article>
</BaseLayout>