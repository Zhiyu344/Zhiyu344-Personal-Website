---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations,formatDate } from '../../../i18n/utils';
import { toTraditional } from '../../../i18n/opencc';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allPosts = await getCollection('blog', ({ id, data }) =>
  id.startsWith('zh-hans/') && !data.draft
);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`${t('blog.pageTitle')} | Zhiyu344`}>
  <div class="relative overflow-hidden min-h-[85vh] py-20 sm:py-28">
    <div class="absolute inset-0 -z-10 pointer-events-none overflow-hidden">
        <div class="absolute top-10 left-4 sm:left-10 w-[clamp(140px,32vw,288px)] h-[clamp(140px,32vw,288px)] bg-candle-300/30 sm:bg-candle-300/40 dark:bg-candle-400/15 rounded-full filter blur-2xl md:blur-3xl animate-float"></div>
        <div class="absolute top-10 right-4 sm:right-10 w-[clamp(140px,32vw,288px)] h-[clamp(140px,32vw,288px)] bg-dusk-300/30 sm:bg-dusk-300/40 dark:bg-dusk-400/15 rounded-full filter blur-2xl md:blur-3xl animate-float" style="animation-delay: 2s;"></div>
        <div class="hidden sm:block absolute -bottom-8 left-20 w-[clamp(180px,28vw,288px)] h-[clamp(180px,28vw,288px)] bg-candle-200/40 sm:bg-candle-200/50 dark:bg-candle-300/20 rounded-full filter blur-2xl md:blur-3xl animate-float" style="animation-delay: 4s;"></div>
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-night-900 dark:text-sky-50">
        {t('blog.pageTitle')}
      </h1>
      <p class="mt-3 text-base sm:text-lg text-night-600 dark:text-abyss-200">
        {t('blog.pageIntro')}
      </p>

      <ul class="mt-12 space-y-8">
        {posts.map(post => {
          const slug = post.id.replace('zh-hans/', '');
          return (
            <li class="border-b border-abyss-100 dark:border-abyss-700 pb-8 last:border-0">
              <a href={`/zh-hant/blog/${slug}`} class="group block">
                <h2 class="text-xl sm:text-2xl font-semibold text-abyss-700 dark:text-sky-100 group-hover:text-candle-500 dark:group-hover:text-candle-400 transition-colors">
                  {toTraditional(post.data.title)}
                </h2>
                <p class="mt-1 text-sm text-night-500 dark:text-abyss-300">
                  {formatDate(post.data.pubDate, lang)}
                </p>
                <p class="mt-2 text-night-600 dark:text-abyss-200">{toTraditional(post.data.description)}</p>
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map(tag => (
                      <span class="text-xs px-2 py-1 rounded-full bg-dusk-50 dark:bg-abyss-800 text-dusk-700 dark:text-dusk-200">
                        {toTraditional(tag)}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</BaseLayout>