---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import Button from '../components/Button.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout title={`${t('404.title')} | Zhiyu344`}>
    <div class="relative overflow-hidden flex-grow flex items-center justify-center py-20 sm:py-28">
        <div class="absolute inset-0 -z-10 pointer-events-none overflow-hidden">
            <div class="absolute top-10 left-10 w-72 h-72 bg-candle-300/40 dark:bg-candle-400/15 rounded-full filter blur-3xl animate-float"></div>
            <div class="absolute bottom-10 right-10 w-72 h-72 bg-dusk-300/40 dark:bg-dusk-400/15 rounded-full filter blur-3xl animate-float" style="animation-delay: 2s;"></div>
        </div>

        <div class="absolute top-10 left-10 w-72 h-72 bg-candle-300/40 dark:bg-candle-400/15 rounded-full filter blur-3xl animate-float"></div>
        <div class="absolute bottom-10 right-10 w-72 h-72 bg-dusk-300/40 dark:bg-dusk-400/15 rounded-full filter blur-3xl animate-float" style="animation-delay: 2s;"></div>

        <div class="relative text-center px-4">
            <p class="text-6xl sm:text-7xl md:text-8xl font-extrabold bg-gradient-to-r from-abyss-500 to-abyss-800 dark:from-abyss-300 dark:to-sky-200 bg-clip-text text-transparent">404</p>
            <h1 class="mt-4 text-2xl sm:text-3xl md:text-4xl font-bold text-night-900 dark:text-sky-50" data-i18n-key="404.title">
                {t('404.title')}
            </h1>
            <p class="mt-2 text-base sm:text-lg text-night-600 dark:text-abyss-200 max-w-sm mx-auto" data-i18n-key="404.message">
                {t('404.message')}
            </p>
            <Button href="/" id="notfound-home-link" variant="primary" class="mt-10" data-i18n-key="404.backHome">
                {t('404.backHome')}
            </Button>
        </div>
    </div>
</BaseLayout>

<script>
    const homeLink = document.getElementById('notfound-home-link') as HTMLAnchorElement | null;
    const path = window.location.pathname;
    const currentLang = path.startsWith('/zh-hant') ? 'zh-hant' : path.startsWith('/zh-hans') ? 'zh-hans' : 'en';
    if (homeLink && currentLang !== 'en') homeLink.href = `/${currentLang}/`;
</script>